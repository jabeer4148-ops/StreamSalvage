# IMPORTANT: This value is embedded at COMPILE TIME via build.rs
# You must have this set in your environment WHEN YOU RUN:
#   npm run tauri build
# Setting it after build has no effect on the shipped binary.
# For development: any value works (TEST- prefix bypass is active in debug builds)
# For production release: must be your real Lemon Squeezy API key
LEMON_SQUEEZY_API_KEY=your_lemon_squeezy_api_key_here
